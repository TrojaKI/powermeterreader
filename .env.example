# Required
SERIAL_PORT=/dev/ttyUSB0
GUEK=36C66639E48A8CA4D68C8B282A793BB8

# MQTT (optional — omit to disable)
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_TOPIC_PREFIX=smartmeter

# InfluxDB 2.x (optional — omit to disable)
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=your-influxdb-token
INFLUX_ORG=your-org
INFLUX_BUCKET=smartmeter
